  "npcs": [
    {
      "id": "npc_receptionist",
      "name": "Receptionist",
      "position": {
        "x": 23.9,
        "y": 63.2
      },
      "color": "0xff6600",
      "dialogueTreeId": "receptionist_intro"
    }
  ],
  "dialogues": {
    "receptionist_intro": {
      "id": "receptionist_intro",
      "start": "greeting",
      "nodes": {
        "greeting": {
          "speaker": "Receptionist",
          "text": "Welcome to AdrianLAB! Are you here for the tour or the experiments?",
          "choices": [
            {
              "text": "The tour, please.",
              "next": "tour"
            },
            {
              "text": "What experiments?",
              "next": "experiments"
            },
            {
              "text": "What about Patient Zero?",
              "next": "patient_zero"
            },
            {
              "text": "[Requires AdrianZERO] Show my badge.",
              "next": "vip",
              "gate": {
                "type": "ERC721",
                "contract": "0x6e369bf0e4e0c106192d606fb6d85836d684da75",
                "minBalance": 1
              }
            }
          ]
        },
        "tour": {
          "speaker": "Receptionist",
          "text": "The lobby connects to all areas. Upstairs is the trading floor. The entrance leads outside. Oh, and whoever left their coat on the rack should really clean out their pockets.",
          "end": true
        },
        "experiments": {
          "speaker": "Receptionist",
          "text": "Oh, you know... turning pixels into tokens, tokens into dreams, dreams into... well, mostly gas fees. But sometimes magic!",
          "choices": [
            {
              "text": "Does 'Patient Zero' ring a bell?",
              "next": "patient_zero"
            },
            {
              "text": "Interesting. Thanks.",
              "next": "experiments_end"
            }
          ]
        },
        "experiments_end": {
          "speaker": "Receptionist",
          "text": "Anytime! Let me know if you need anything else.",
          "end": true
        },
        "patient_zero": {
          "speaker": "Receptionist",
          "text": "Patient Zero? I... I don't know what you're talking about. That's a basement-level clearance topic.",
          "onEnter": [
            {
              "op": "setFlag",
              "flag": "receptionist_mentioned_pz",
              "value": true
            }
          ],
          "choices": [
            {
              "text": "You seem nervous about it.",
              "next": "pz_nervous"
            },
            {
              "text": "Forget I asked.",
              "next": "pz_forget"
            }
          ]
        },
        "pz_nervous": {
          "speaker": "Receptionist",
          "text": "Nervous? Me? Ha! I just... look, some things in this building are above my pay grade. WAY above. If you want answers about... that... you'd need to go deeper. Literally.",
          "end": true
        },
        "pz_forget": {
          "speaker": "Receptionist",
          "text": "Already forgotten! Ha ha... ha. Please don't mention that name again. Especially not near the basement.",
          "end": true
        },
        "vip": {
          "speaker": "Receptionist",
          "text": "An AdrianZERO holder! VIP access granted. The basement has a special terminal for holders. The rug under the entrance hides the way down.",
          "end": true
        }
      }
    }
  },
  "items": {
    "sceneItems": []
  },
  "combos": [
