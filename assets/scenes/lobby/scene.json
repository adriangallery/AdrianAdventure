              "text": "The plant is already blooming. It doesn't need more water."
            }
          ],
          "else": [
            {
              "op": "say",
              "text": "I pour the spring water on the crypto-plant. It erupts with growth! Leaves unfurl, a golden pod emerges from the soil..."
            },
            {
              "op": "setFlag",
              "flag": "plant_watered",
              "value": true
            },
            {
              "op": "removeItem",
              "id": "water_bottle"
            },
            {
              "op": "wait",
              "ms": 600
            },
            {
              "op": "addItem",
              "id": "golden_token",
              "name": "Golden ZERO Token"
            },
            {
              "op": "say",
              "text": "Inside the pod: a golden token engraved with 'ZERO'. The plant whisperer's reward."
            }
          ]
        }
      ]
    }
  ],
