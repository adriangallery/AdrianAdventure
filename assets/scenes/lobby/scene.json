  "regions": {
    "hotspots": [
      {
        "id": "hs_stairs_up",
        "name": "Stairs to Upstairs",
        "bounds": {
          "x": 65.5,
          "y": 2.6,
          "w": 19.7,
          "h": 33.5
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "Stairs leading to the upper floor. Elegantly designed with smart lighting."
            }
          ],
          "USE": [
            {
              "op": "sayBrief",
              "text": "Heading upstairs.",
              "duration": 1000
            },
            {
              "op": "fadeToScene",
              "sceneId": "upstairs",
              "spawn": {
                "x": 8.8,
                "y": 97.9
              },
              "duration": 600
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "The stairs creak: 'Level up, anon...'"
            }
          ],
          "PICK": [
            {
              "op": "say",
              "text": "I find a small LED light on the railing. Cute but useless."
            }
          ],
          "OPEN": [
            {
              "op": "say",
              "text": "I notice a hidden compartment under one step. Empty though."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "The stairs are always open for access between floors."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I push the handrail. Sturdy."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I pull the railing. A loose bolt falls."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "Stairs don't accept tips."
            }
          ]
        }
      },
      {
        "id": "hs_plant",
        "name": "Lobby Plant",
        "bounds": {
          "x": 39.9,
          "y": 44,
          "w": 5,
          "h": 20
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "A tall plant in a ceramic pot. It looks thirsty. Really thirsty."
            }
          ],
          "USE": [
            {
              "op": "say",
              "text": "I have nothing to water it with. The plant droops judgmentally."
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "The plant hums photosynthetically. 'Water... me...'"
            }
          ],
          "PICK": [
            {
              "op": "say",
              "text": "I can't carry a plant this big."
            }
          ],
          "OPEN": [
            {
              "op": "say",
              "text": "I dig in the soil. Just dirt and roots."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "I pat the soil back."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I push the pot. It scrapes the floor."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I pull a leaf. The plant recoils."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "The plant accepts water. I don't have any."
            }
          ]
        }
      },
      {
        "id": "hs_frontdoor",
        "name": "Main Entrance",
        "bounds": {
          "x": 90.5,
          "y": 22.2,
          "w": 6.2,
          "h": 68.2
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "The front door from the inside. Through the frosted glass I can see the porch. The lock mechanism is impressively complex."
            }
          ],
          "USE": [
            {
              "op": "sayBrief",
              "text": "Back to the entrance.",
              "duration": 1000
            },
            {
              "op": "fadeToScene",
              "sceneId": "outside",
              "spawn": {
                "x": 41.3,
                "y": 90.6
              },
              "duration": 500
            }
          ],
          "OPEN": [
            {
              "op": "sayBrief",
              "text": "Back to the entrance.",
              "duration": 1000
            },
            {
              "op": "fadeToScene",
              "sceneId": "outside",
              "spawn": {
                "x": 41.3,
                "y": 90.6
              },
              "duration": 500
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "The door creaks. In door language, that means 'please oil me'."
            }
          ],
          "PICK": [
            {
              "op": "say",
              "text": "I can't pick up a door. I've tried before in other games."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "It's already closed."
            }
          ],
          "PUSH": [
            {
              "op": "sayBrief",
              "text": "Back to the entrance.",
              "duration": 1000
            },
            {
              "op": "fadeToScene",
              "sceneId": "outside",
              "spawn": {
                "x": 41.3,
                "y": 90.6
              },
              "duration": 500
            }
          ],
          "PULL": [
            {
              "op": "sayBrief",
              "text": "Back to the entrance.",
              "duration": 1000
            },
            {
              "op": "fadeToScene",
              "sceneId": "outside",
              "spawn": {
                "x": 41.3,
                "y": 90.6
              },
              "duration": 500
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "I have nothing to give a door."
            }
          ]
        }
      },
      {
        "id": "hs_coat",
        "name": "Wool Coat",
        "bounds": {
          "x": 53.3,
          "y": 32.4,
          "w": 4.8,
          "h": 36.1
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "A heavy wool overcoat. Multiple pockets, each containing a different defunct exchange's branded pen. The lining is stitched with the words 'DYOR' in tiny letters."
            }
          ],
          "USE": [
            {
              "op": "say",
              "text": "I check the pockets. Pens from FTX, Celsius, BlockFi... a graveyard of exchanges."
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "The coat rustles. Ghosts of bear markets past."
            }
          ],
          "PICK": [
            {
              "op": "ifFlag",
              "flag": "found_keycard",
              "then": [
                {
                  "op": "say",
                  "text": "I already took the keycard. Just dead exchange pens left."
                }
              ],
              "else": [
                {
                  "op": "setFlag",
                  "flag": "found_keycard",
                  "value": true
                },
                {
                  "op": "setFlag",
                  "flag": "has_keycard",
                  "value": true
                },
                {
                  "op": "addItem",
                  "id": "keycard",
                  "name": "Adrian's Keycard"
                },
                {
                  "op": "say",
                  "text": "I search the deep pockets... buried under pens and receipts, I find a keycard! It says 'ADMIN ACCESS — AdrianLAB'."
                }
              ]
            }
          ],
          "OPEN": [
            {
              "op": "ifFlag",
              "flag": "found_keycard",
              "then": [
                {
                  "op": "say",
                  "text": "I already took the keycard. Just dead exchange pens left."
                }
              ],
              "else": [
                {
                  "op": "setFlag",
                  "flag": "found_keycard",
                  "value": true
                },
                {
                  "op": "setFlag",
                  "flag": "has_keycard",
                  "value": true
                },
                {
                  "op": "addItem",
                  "id": "keycard",
                  "name": "Adrian's Keycard"
                },
                {
                  "op": "say",
                  "text": "I open the coat pockets. Inside the breast pocket: an admin keycard with Adrian's face."
                }
              ]
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "I button the coat. It looks dignified on its hook."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I push the coat aside. Just the wall behind it."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I pull the coat off the hook. Heavy. I put it back — I have enough baggage."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "Nobody wants a coat full of dead exchange pens."
            }
          ]
        }
      },
      {
        "id": "hs_bucket",
        "name": "Cleaning Bucket",
        "bounds": {
          "x": 3,
          "y": 78,
          "w": 6,
          "h": 12
        },
        "scripts": {
          "LOOK": [
            {
              "op": "ifFlag",
              "flag": "found_rubber_duck",
              "then": [
                {
                  "op": "say",
                  "text": "An empty cleaning bucket. It looks lonely without its rubber duck."
                }
              ],
              "else": [
                {
                  "op": "say",
                  "text": "A janitor's cleaning bucket. Something yellow is floating in the murky water."
                }
              ]
            }
          ],
          "USE": [
            {
              "op": "say",
              "text": "I'm not cleaning anything. I'm investigating."
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "I address the bucket. The water ripples. Coincidence? Probably."
            }
          ],
          "PICK": [
            {
              "op": "ifFlag",
              "flag": "found_rubber_duck",
              "then": [
                {
                  "op": "say",
                  "text": "Nothing else in the bucket. Just dirty water."
                }
              ],
              "else": [
                {
                  "op": "say",
                  "text": "I fish around in the murky water and pull out... a rubber duck? Who brings a rubber duck to a crypto lab?"
                },
                {
                  "op": "addItem",
                  "id": "rubber_duck",
                  "name": "Rubber Duck"
                },
                {
                  "op": "setFlag",
                  "flag": "found_rubber_duck",
                  "value": true
                }
              ]
            }
          ],
          "OPEN": [
            {
              "op": "say",
              "text": "Buckets don't open. They're already open. That's their whole design philosophy."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "No lid. This bucket lives life on the edge."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I kick the bucket. Wait — poor choice of words. The water sloshes."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I drag the bucket. It leaves a wet trail. The janitor won't be happy."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "Nobody wants a dirty bucket. I don't blame them."
            }
          ]
        }
      },
      {
        "id": "hs_monitor_desk",
        "name": "Monitor Desk",
        "bounds": {
          "x": 3,
          "y": 22,
          "w": 33,
          "h": 42
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "Five CRT monitors showing trading charts, terminal windows, and what appears to be a live blockchain explorer. The 90s hardware running 2020s defi. Retro-futurism at its finest."
            }
          ],
          "USE": [
            {
              "op": "say",
              "text": "I wiggle the mouse. All five screens wake up. One shows a yield farm dashboard. Another shows the mempool. The third... is that Minesweeper?"
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "'Show me the money!' The monitors hum louder. A chart goes green for a second. Then red. Classic."
            },
            {
              "op": "setFlag",
              "flag": "debug_look_1",
              "value": true
            }
          ],
          "PICK": [
            {
              "op": "say",
              "text": "These CRTs weigh about 40 pounds each. My back says absolutely not."
            }
          ],
          "OPEN": [
            {
              "op": "say",
              "text": "I open a desk drawer. Floppy disks labeled 'SEED PHRASE BACKUP - DO NOT LOSE'. In a desk drawer. In a lobby. Adrian..."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "I close the drawer. Some secrets are better left undiscovered. For now."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I push the desk. A CRT wobbles dangerously. The trading bot onscreen panics: 'EARTHQUAKE DETECTED — SELLING EVERYTHING!'"
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I pull open the keyboard tray. Crumbs everywhere. The snack history of a true degen."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "The monitors don't accept deposits. Only the smart contracts do."
            }
          ]
        }
      },
      {
        "id": "hs_ceiling_light",
        "name": "Ceiling Light",
        "bounds": {
          "x": 47,
          "y": 5,
          "w": 6,
          "h": 15
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "A vintage pendant lamp casting a warm cone of light. It flickers every few seconds. Proof-of-work lighting — uses way more energy than it should."
            }
          ],
          "USE": [
            {
              "op": "say",
              "text": "I pull the chain. The light dims. I pull again. Bright. Dim. Bright. I'm basically a human light switch now."
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "The bulb buzzes. In Morse code, that translates to 'replace me, I'm dying.' Noted."
            }
          ],
          "PICK": [
            {
              "op": "say",
              "text": "Too high to reach without a ladder. Even on my tiptoes. Especially on my tiptoes."
            }
          ],
          "OPEN": [
            {
              "op": "say",
              "text": "I can't open a ceiling light. That's not how lighting works."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "Lights don't close. They turn off. Different verb, same disappointment."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I push the air beneath the lamp. The lamp is unaffected by my pathetic display."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I jump and grab the chain. The light swings wildly. Shadows dance on the walls like a bear market panic."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "I offer the lamp a new bulb. Oh wait, I don't have one. Just empty promises, like every roadmap."
            }
          ]
        }
      },
      {
        "id": "hs_floor_tiles",
        "name": "Checkered Floor",
        "bounds": {
          "x": 10,
          "y": 84,
          "w": 75,
          "h": 10
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "Checkered brown and tan tiles. Classic. Like a chessboard where every move is 'buy high, sell low.'"
            }
          ],
          "USE": [
            {
              "op": "say",
              "text": "I tap-dance on the tiles. The acoustics are surprisingly good. The receptionist stares."
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "I kneel and whisper to the floor. 'Any secret basements down there?' The tiles remain tight-lipped."
            }
          ],
          "PICK": [
            {
              "op": "say",
              "text": "I try to pry up a tile. It's cemented. Immutable, like a good blockchain."
            }
          ],
          "OPEN": [
            {
              "op": "say",
              "text": "One tile seems slightly loose but I can't lift it. Need better tools. Or worse morals."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "The floor is already as closed as it gets."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I stomp on the floor. Solid. No hollow sounds. No secret passages. Yet."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I scratch at the grout between tiles. Nothing gives. Whoever laid these tiles was not messing around."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "The floor accepts only footsteps. And the occasional dropped coin that rolls under the desk forever."
            }
          ]
        }
      }
    ],
    "triggers": [
