          "OPEN": [
            {
              "op": "say",
              "text": "No attic access from outside."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "Good roof. Doing its job."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I can't reach the roof from here."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I'm not pulling tiles off a roof."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "The pigeons up there don't want anything."
            }
          ]
        }
      },
      {
        "id": "hs_carport",
        "name": "Carport",
        "bounds": {
          "x": 69.3,
          "y": 57.4,
          "w": 15,
          "h": 30
        },
        "scripts": {
          "LOOK": [
            {
              "op": "say",
              "text": "Empty carport. Oil stains but no car. Someone left in a hurry."
            }
          ],
          "USE": [
            {
              "op": "say",
              "text": "Nothing to use. Eerily empty."
            }
          ],
          "TALK": [
            {
              "op": "say",
              "text": "Footsteps echo. Ghost of a Lambo."
            }
          ],
          "PICK": [
            {
              "op": "say",
              "text": "Oil stains. Not useful."
            }
          ],
          "OPEN": [
            {
              "op": "say",
              "text": "Already open. More suggestion than shelter."
            }
          ],
          "CLOSE": [
            {
              "op": "say",
              "text": "Open-source parking doesn't close."
            }
          ],
          "PUSH": [
            {
              "op": "say",
              "text": "I push the carport beam. It wobbles slightly."
            }
          ],
          "PULL": [
            {
              "op": "say",
              "text": "I pull on the roof edge. Dust falls."
            }
          ],
          "GIVE": [
            {
              "op": "say",
              "text": "The ghost Lambo doesn't need fuel."
            }
          ]
        }
      },
