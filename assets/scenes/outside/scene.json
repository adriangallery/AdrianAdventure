      {
        "id": "hs_sunset_sky",
        "name": "Sunset Sky",
        "bounds": { "x": 0, "y": 0, "w": 30, "h": 10 },
        "scripts": {
          "LOOK": [{ "op": "say", "text": "A blazing pink and orange sunset. Like watching a candlestick chart go parabolic across the entire sky." }],
          "USE": [{ "op": "say", "text": "I try to screenshot the sunset. My phone camera does NOT do it justice. Some things can't be minted." }],
          "TALK": [{ "op": "say", "text": "'Hey sky, when moon?' The clouds drift silently. Even the atmosphere won't give me alpha." }],
          "PICK": [{ "op": "say", "text": "I reach for the sunset. My arm isn't long enough. Story of my trading career." }],
          "OPEN": [{ "op": "say", "text": "Can't open the sky. It's already the most permissionless thing in existence." }],
          "CLOSE": [{ "op": "say", "text": "The sun is closing on its own. Give it twenty minutes." }],
          "PUSH": [{ "op": "say", "text": "I push against the fading light. Physics remains unimpressed." }],
          "PULL": [{ "op": "say", "text": "I try to pull the sunset back. Time only moves in one direction. Like my portfolio." }],
          "GIVE": [{ "op": "say", "text": "The sky doesn't accept offerings. Not even gas fees." }]
        }
      },
      {
        "id": "hs_fence",
        "name": "Wooden Fence",
        "bounds": { "x": 0, "y": 45, "w": 5, "h": 30 },
        "scripts": {
          "LOOK": [{ "op": "say", "text": "A weathered wooden fence marking the property line. Some planks are missing. Like gaps in a liquidity pool." }],
          "USE": [{ "op": "say", "text": "I lean on the fence. It creaks but holds. More reliable than most DeFi protocols." }],
          "TALK": [{ "op": "say", "text": "'Good fences make good neighbors.' The fence says nothing. It's a fence." }],
          "PICK": [{ "op": "say", "text": "I pull a loose splinter off. Ouch. Not worth the gas fees." }],
          "OPEN": [{ "op": "say", "text": "No gate here. Just fence all the way. Permissioned access only." }],
          "CLOSE": [{ "op": "say", "text": "The fence is already doing its best impression of a closed position." }],
          "PUSH": [{ "op": "say", "text": "I push the fence. It leans. One more push and Adrian's property value drops 3%." }],
          "PULL": [{ "op": "say", "text": "I pull a plank. It comes loose. Now there's an exploit in the perimeter." }],
          "GIVE": [{ "op": "say", "text": "The fence doesn't want anything. It just wants to be left alone. Relatable." }]
        }
      },
      {
        "id": "hs_upper_windows",
        "name": "Upper Floor Windows",
        "bounds": { "x": 21, "y": 18, "w": 18, "h": 20 },
        "scripts": {
          "LOOK": [{ "op": "say", "text": "Four windows glow warmly on the second floor. Multiple monitor screens visible inside. Someone was running serious operations up there." }],
          "USE": [{ "op": "say", "text": "Too high to reach from here. I'd need to get inside first." }],
          "TALK": [{ "op": "say", "text": "'Anyone trading up there?!' The glow of the screens is the only answer. The bots never sleep." }],
          "PICK": [{ "op": "say", "text": "Can't reach the second floor. I'm not Spider-Man. I'm more of a rug-pull survivor." }],
          "OPEN": [{ "op": "say", "text": "Way too high. I'd need a ladder or a very optimistic leverage position." }],
          "CLOSE": [{ "op": "say", "text": "The curtains are already half-drawn. Privacy mode: on." }],
          "PUSH": [{ "op": "say", "text": "I push against the wall below the windows. The house doesn't budge. Solid foundation." }],
          "PULL": [{ "op": "say", "text": "I try to pull myself up toward the windows. Gravity says no. Hard no." }],
          "GIVE": [{ "op": "say", "text": "I can't give anything to windows I can't reach. Story of every failed airdrop claim." }]
        }
      }
    ],
